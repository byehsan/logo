{
  "name": "@byehsan/logo",
  "version": "2.0.0",
  "description": "byEhsan brand logo system — triskelion mark, state animations, HTTP error states, lockups, favicons",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".":              { "import": "./dist/index.esm.js", "require": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./css":          "./dist/index.css",
    "./states-css":   "./dist/states.css",
    "./palette":      "./dist/palette.json"
  },
  "scripts": {
    "build":    "node scripts/bundle.mjs",
    "validate": "find . -name '*.svg' -not -path './.git/*' -not -path './dist/*' | xargs xmllint --noout",
    "preview":  "open preview.html || xdg-open preview.html"
  },
  "files": [
    "dist/",
    "base.svg",
    "states/",
    "http/",
    "lockup/",
    "palette.json",
    "states.css"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "keywords": ["byehsan", "logo", "brand", "svg", "triskelion", "design-system"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/byehsan/logo.git"
  },
  "homepage": "https://byehsan.github.io/logo/"
}
